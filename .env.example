# =====================================================================
# Auto-Worker AI System — Environment Configuration
# Copy this file to .env and fill in your values
# =====================================================================

# --- PostgreSQL (used by Docker Compose) ---
POSTGRES_USER=aw_user
POSTGRES_PASSWORD=aw_password
POSTGRES_DB=aw_db
DATABASE_URL=postgresql+asyncpg://aw_user:aw_password@localhost:5432/aw_db

# --- Redis (used by Docker Compose) ---
REDIS_URL=redis://localhost:6379/0

# =====================================================================
# LLM APIs — Priority: Groq (FREE) > Gemini (FREE) > OpenAI (Paid)
# The system auto-selects the first key that is set.
# =====================================================================

# 1. GROQ — FREE tier: 14,400 req/day, 20k tokens/min (NO credit card needed)
#    Get key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# 2. GEMINI — FREE tier: 1,500 req/day (NO credit card needed)
#    Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 3. OPENAI — Paid fallback only
OPENAI_API_KEY=your_openai_api_key_here

# =====================================================================
# Observability (optional — leave as-is to disable)
# =====================================================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT="auto_worker_system"
CREWAI_TRACING_ENABLED=false

# =====================================================================
# Web Search (optional — Research Agent uses DuckDuckGo by default, FREE)
# Only needed if you want Tavily's enhanced search quality
# =====================================================================
TAVILY_API_KEY=your_tavily_api_key_here
